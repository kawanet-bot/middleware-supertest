{
  "name": "middleware-supertest",
  "description": "Testing Express.js RequestHandler middlewares both on server-side and client-side",
  "version": "1.1.0",
  "author": "Yusuke Kawasaki <u-suke@kawa.net>",
  "bugs": {
    "url": "https://github.com/kawanet/middleware-supertest/issues"
  },
  "contributors": [
    "Yusuke Kawasaki <u-suke@kawa.net>"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "express-intercept": "^1.0.0",
    "supertest": "^6.3.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.2",
    "@rollup/plugin-sucrase": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/node": "^24.0.0",
    "@types/supertest": "^2.0.16",
    "rollup": "^4.52.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "require": "./dist/middleware-supertest.cjs",
      "import": {
        "types": "./types/middleware-supertest.d.ts",
        "default": "./dist/middleware-supertest.mjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/middleware-supertest.cjs",
    "dist/middleware-supertest.mjs",
    "dist/package.json",
    "lib/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/middleware-supertest#readme",
  "keywords": [
    "assert",
    "expressjs",
    "middleware",
    "supertest",
    "test"
  ],
  "license": "MIT",
  "main": "./dist/middleware-supertest.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/middleware-supertest.git"
  },
  "scripts": {
    "build": "make -C builder",
    "fixpack": "fixpack",
    "prepack": "make -C builder test",
    "prepare": "make -C builder clean all",
    "test": "make -C builder test"
  },
  "sideEffects": false,
  "type": "module",
  "types": "types/middleware-supertest.d.ts"
